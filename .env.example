# ── Database (PostgreSQL) ──────────────────────────────
# Optional for demo — the app works without a database.
# Anomaly history and health snapshots won't persist without it.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/edgeai?schema=public
DIRECT_URL=postgresql://postgres:postgres@localhost:5433/edgeai?schema=public

# ── Google Gemini ──────────────────────────────────────
# Optional for demo — AI diagnostics & maintenance planner.
# Leave blank to run without AI (the UI shows a graceful fallback).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── NextAuth ───────────────────────────────────────────
# Required — change the secret for production.
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3000
